{
  "expo": {
    "name": "LifeMaintained",
    "slug": "lifemaintained",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifemaintained",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C111B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifemaintained.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "LifeMaintained uses your microphone to log maintenance by voice.",
        "NSCameraUsageDescription": "LifeMaintained uses your camera to scan receipts and take vehicle photos.",
        "NSPhotoLibraryUsageDescription": "LifeMaintained accesses your photos to attach receipts and vehicle images.",
        "NSPhotoLibraryAddUsageDescription": "LifeMaintained saves exported documents to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lifemaintained.app",
      "adaptiveIcon": {
        "backgroundColor": "#0C111B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://lifemaintained.com"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E8943A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LifeMaintained accesses your photos to attach receipts and vehicle images.",
          "cameraPermission": "LifeMaintained uses your camera to scan receipts and take vehicle photos."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "LifeMaintained uses your microphone to log maintenance by voice."
        }
      ],
      "@react-native-community/datetimepicker",
      "@sentry/react-native",
      [
        "@sentry/react-native/expo",
        {
          "organization": "frameworkuno",
          "project": "lifemaintained",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://lifemaintained.com"
      },
      "eas": {
        "projectId": "2b817e52-5d6d-43c4-9855-966f7ded10ad"
      },
      "sentryDsn": "${SENTRY_DSN}"
    }
  }
}
